// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          String           @id @default(uuid())
  name        String?
  savedWords  UserSavedWord[]
  createdAt   DateTime         @default(now())
}

model Teacher {
  id          String     @id @default(uuid())
  name        String
  specialty   String
  price       Float      @default(60.0)
  imageUrl    String?
  schedules   Schedule[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Schedule {
  id        String   @id @default(uuid())
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  date      DateTime
  isBooked  Boolean  @default(false)
  bookings  Booking[]
}

model Booking {
  id         String   @id @default(uuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id])
  studentId  String
  paymentId  String?
  status     String   @default("PENDING")
  meetLink   String?
  createdAt  DateTime @default(now())
}

model DictionaryEntry {
  id          String   @id @default(cuid())
  kanji       String?  // Pode ser nulo se só tiver kana
  reading     String   // Hiragana/Katakana
  romaji      String?  // Romaji
  meaningPt   String   // Significado em Português
  meaningEn   String?  // Fallback em Inglês
  jlptLevel   Int?     // N5 (5) ao N1 (1)
  isCommon    Boolean  @default(false)
  
  savedByUsers UserSavedWord[]
  
  @@index([kanji])
  @@index([reading])
}

model UserSavedWord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  wordId     String
  word       DictionaryEntry @relation(fields: [wordId], references: [id])
  createdAt  DateTime @default(now())
  nextReview DateTime?
}
